# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://mbolo:mbolo_dev@localhost:5432/mbolo_sante"

# ─── Redis (sessions OTP) ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Authentification JWT ─────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Expo Push Notifications ──────────────────────────────────────────────────
# Laisser vide → StubPushProvider (logs console seulement)
# Obtenir sur https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=""

# ─── MyPVIT — Mobile Money (Airtel Money / Moov Money Gabon) ─────────────────
# Laisser vide en dev → StubPaymentProvider activé automatiquement
# Créer un compte sur https://mypvit.pro et récupérer les paramètres dans le dashboard
MYPVIT_BASE_URL="https://api.mypvit.pro/v2"
MYPVIT_URL_CODE=""
MYPVIT_OPERATION_ACCOUNT_CODE=""
MYPVIT_API_PASSWORD=""
MYPVIT_CALLBACK_URL_CODE=""

# ─── Daily.co — Vidéo consultation ───────────────────────────────────────────
# Laisser vide → StubVideoProvider (URLs de test générées localement)
# Créer un compte sur https://www.daily.co et copier la clé API dans le dashboard
DAILY_API_KEY=""
DAILY_DOMAIN="mbolo.daily.co"

# ─── WhatsApp — Meta Cloud API (canal de notification prioritaire) ───────────
# Laisser vide → StubNotificationProvider (logs console). Sinon, le canal
# prioritaire bascule sur WhatsApp ; le SMS Africa's Talking sert de repli.
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_API_VERSION="v21.0"

# ─── Africa's Talking — SMS (repli) ──────────────────────────────────────────
# Laisser vide → StubNotificationProvider (logs console seulement)
# https://africastalking.com — créer un compte et activer la sandbox
AT_USERNAME=""
AT_API_KEY=""
AT_SENDER_ID="MBOLO"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origines autorisées pour le dashboard web admin (séparées par des virgules)
CORS_ORIGINS="http://localhost:5173,https://admin.mbolo-sante.com"
